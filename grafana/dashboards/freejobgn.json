{
  "uid": "freejobgn-main",
  "title": "FreeJobGN — Overview",
  "tags": ["freejobgn", "django"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Taux de requêtes HTTP",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status) (rate(django_http_responses_total_by_status_total[5m]))",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Latence P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m])))",
          "legendFormat": "P50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m])))",
          "legendFormat": "P95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Taux d'erreur 5xx",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_total[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Utilisateurs total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(freejobgn_users_total)",
          "legendFormat": "Utilisateurs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 5,
      "title": "Abonnements actifs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(freejobgn_active_subscriptions_by_tier)",
          "legendFormat": "Abonnements"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 6,
      "title": "Paiements réussis",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_payment_transactions_total{status=\"SUCCESS\"}",
          "legendFormat": "Success"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 7,
      "title": "Paiements échoués",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_payment_transactions_total{status=\"FAILED\"}",
          "legendFormat": "Échoués"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Webhooks INVALID_SIGNATURE",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_webhooks_total{state=\"invalid_signature\"}",
          "legendFormat": "Sig. invalide"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Utilisateurs par rôle",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_users_total",
          "legendFormat": "{{role}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Abonnements actifs par tier",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_active_subscriptions_by_tier",
          "legendFormat": "{{tier}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Projets par statut",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_projects_total",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Contrats par statut",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_contracts_total",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Transactions Wallet par type",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_wallet_transactions_total",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 14,
      "title": "Webhooks par état",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_webhooks_total",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 15,
      "title": "Requêtes DB / seconde",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(django_db_execute_total[5m])",
          "legendFormat": "Queries/s ({{vendor}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 16,
      "title": "Mémoire RSS du process",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ]
}
