{
  "uid": "freejobgn-slo",
  "title": "FreeJobGN — SLO (Service Level Objectives)",
  "tags": ["freejobgn", "slo"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Disponibilité API (objectif: 99.9%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "avg_over_time(up{job=\"freejobgn-django\"}[30d]) * 100",
          "legendFormat": "Disponibilité %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "yellow", "value": 99.5 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Latence P95 actuelle (objectif: < 500ms)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m]))) * 1000",
          "legendFormat": "P95 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 2000,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 1500 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Taux de succès paiements (objectif: > 98%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * freejobgn_payment_transactions_total{status=\"SUCCESS\"} / (sum(freejobgn_payment_transactions_total) > 0)",
          "legendFormat": "% Succès"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 98 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Taux d'erreur 5xx (objectif: < 1%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_total[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Évolution disponibilité — 30 jours",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "avg_over_time(up{job=\"freejobgn-django\"}[1h]) * 100",
          "legendFormat": "Disponibilité (rolling 1h) %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Latence P50 / P95 / P99 — 30 jours",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m]))) * 1000",
          "legendFormat": "P50 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m]))) * 1000",
          "legendFormat": "P95 (ms)"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_total_bucket[5m]))) * 1000",
          "legendFormat": "P99 (ms)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 7,
      "title": "Taux d'erreur 5xx — historique",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_total[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Requêtes / seconde — toutes routes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(django_http_responses_total_by_status_total[5m]))",
          "legendFormat": "req/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"2..\"}[5m]))",
          "legendFormat": "2xx req/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 9,
      "title": "Budget d'erreur consommé ce mois (SLO 99.9%)",
      "type": "stat",
      "description": "43min/mois autorisées. Valeur = minutes de down estimées.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - avg_over_time(up{job=\"freejobgn-django\"}[30d])) * 30 * 24 * 60",
          "legendFormat": "Minutes de down"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 43 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 10,
      "title": "Paiements SUCCESS ce mois",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_payment_transactions_total{status=\"SUCCESS\"}",
          "legendFormat": "Paiements réussis"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 11,
      "title": "Webhooks signature invalide",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "freejobgn_webhooks_total{state=\"invalid_signature\"}",
          "legendFormat": "INVALID_SIGNATURE"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
